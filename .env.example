# IMPORTANT: wrap any password/secret that contains special characters ($, #,
# backticks, spaces, etc.) in SINGLE quotes. Unquoted and double-quoted values
# undergo variable expansion, so a password like paSs1$2178 silently becomes
# paSs1. Single quotes keep the value literal:  PASSWORD='paSs1$2178'

# Main account for database backup
MAIN_ACCOUNT_PROVIDER=mega
MAIN_ACCOUNT_EMAIL=main@example.com
MAIN_ACCOUNT_PASSWORD='encryptedpass123'

# MEGA accounts (numbered)
MEGA_ACCOUNT_1_EMAIL=mega1@example.com
MEGA_ACCOUNT_1_PASSWORD='pass1'
MEGA_ACCOUNT_1_QUOTA_GB=20

MEGA_ACCOUNT_2_EMAIL=mega2@example.com
MEGA_ACCOUNT_2_PASSWORD=pass2
MEGA_ACCOUNT_2_QUOTA_GB=20

# 4shared accounts. Each 4shared account is authorized through its own
# registered application, so its consumer key/secret/domain and OAuth tokens are
# all per-account (the FOURSHARED_ACCOUNT_<n>_CONSUMER_* keys below). Register the
# app at https://www.4shared.com/developer — see the README "Provider
# credentials" section for the full walkthrough.
#
# EMAIL/PASSWORD are kept for display/reference only; uploads authenticate with
# the OAuth token, obtained once via:  go run ./cmd/fourshared-auth -account 1
FOURSHARED_ACCOUNT_1_EMAIL=4s1@example.com
FOURSHARED_ACCOUNT_1_PASSWORD=pass3
FOURSHARED_ACCOUNT_1_QUOTA_GB=15
# App consumer key/secret for this account's registered application.
FOURSHARED_ACCOUNT_1_CONSUMER_KEY=your_4shared_consumer_key
FOURSHARED_ACCOUNT_1_CONSUMER_SECRET=your_4shared_consumer_secret
# The app's registered "Application domain", pointed at 127.0.0.1 so the
# authorize helper can capture the OAuth callback locally (4shared rejects
# "localhost"). Used only by cmd/fourshared-auth, not at upload time.
FOURSHARED_ACCOUNT_1_CONSUMER_DOMAIN=backmeup.example.com
# Filled in by:  go run ./cmd/fourshared-auth -account 1
FOURSHARED_ACCOUNT_1_OAUTH_TOKEN=
FOURSHARED_ACCOUNT_1_OAUTH_TOKEN_SECRET=

# Add more accounts as needed (FOURSHARED_ACCOUNT_2_*, etc.). If several accounts
# share one application, you can instead set FOURSHARED_CONSUMER_KEY /
# FOURSHARED_CONSUMER_SECRET once as a fallback for accounts that omit their own.

# Add more as needed...
